# بله قربان — Bale Bot Configuration
# Copy this file to .env and fill in your values
# cp env.example .env

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════════════

# Bale bot token (get from @botfather on Bale)
BALE_TOKEN=YOUR_BOT_TOKEN_HERE


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL - Telegram Bot
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram bot token (get from @botfather on Telegram)
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — YouTube Features
# ═══════════════════════════════════════════════════════════════════════════════

# YouTube cookies file for yt-dlp — strongly recommended on datacenter IPs.
# Prevents bot-detection / HTTP 403 errors from YouTube.
# Export with: yt-dlp --cookies-from-browser chrome --cookies /path/yt_cookies.txt https://youtube.com
# YOUTUBE_COOKIES_FILE=

# Cloudflare WARP proxy — routes yt-dlp through residential IP (bypasses datacenter blocks).
# Install: https://pkg.cloudflareclient.com/
# Then run: warp-cli set-mode proxy && warp-cli connect
# Typically listens on socks5://127.0.0.1:40000
# WARP_PROXY=socks5://127.0.0.1:40000

# Cobalt self-hosted API — used as LAST RESORT fallback after all yt-dlp strategies fail.
# yt-dlp is always tried first (quality picker, probe strategies, safety-net).
# Self-host: https://github.com/imputnet/cobalt
# Leave empty to disable Cobalt fallback entirely.
# COBALT_URL=http://localhost:9000


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — GitHub Features
# ═══════════════════════════════════════════════════════════════════════════════

# GitHub personal access token — raises API rate limit from 60 to 5000 req/hour.
# Get from: https://github.com/settings/tokens (no special scopes needed for public repos)
# GITHUB_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Telegram Features
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram API credentials (for reading private/restricted channels via MTProto).
# Get from: https://my.telegram.org → API development tools
# TG_API_ID=
# TG_API_HASH=

# Telegram session file path (stores authentication state between restarts).
# TG_SESSION_FILE=tg_session


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Twitter / X Features
# ═══════════════════════════════════════════════════════════════════════════════

# Twitter cookies file for yt-dlp (needed for age-restricted or login-walled tweets).
# Log into twitter.com in Chrome → export cookies with "Get cookies.txt LOCALLY" extension.
# TWITTER_COOKIES_FILE=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Instagram Features
# ═══════════════════════════════════════════════════════════════════════════════

# Instagram login credentials — used by instaloader for private profiles.
# INSTAGRAM_USER=
# INSTAGRAM_PASS=

# Instagram cookies file — alternative to user/pass for yt-dlp strategy.
# Export from browser the same way as YouTube cookies.
# INSTAGRAM_COOKIES_FILE=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Spotify Features
# ═══════════════════════════════════════════════════════════════════════════════

# Spotify API credentials — used by spotdl for playlist/album downloads.
# Without these, single tracks still work but playlists may be limited.
# Get from: https://developer.spotify.com/dashboard → Create App
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Z-Library Features
# ═══════════════════════════════════════════════════════════════════════════════

# Z-Library account credentials (register free at: https://z-library.sk/login).
# Required for book downloads; search works without login.
# ZLIB_EMAIL=
# ZLIB_PASSWORD=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — VirusTotal Features
# ═══════════════════════════════════════════════════════════════════════════════

# VirusTotal API key (register free at: https://virustotal.com/gui/join-us).
# Required for virus scan.
# IRUSTOTAL_API_KEY=your_64char_vt_key_here