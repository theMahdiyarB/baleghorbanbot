# Bale Bot Configuration
# Copy this file to .env and fill in your values
# Required variables must be set for the bot to run

# ═══════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════════════════════════════════

# Bale bot token (get from @botfather on Bale)
BALE_TOKEN=YOUR_BOT_TOKEN_HERE


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — GitHub Features
# ═══════════════════════════════════════════════════════════════════════════════

# GitHub API token (for accessing private repos, etc.)
# Get from: https://github.com/settings/tokens
# GITHUB_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — YouTube Features
# ═══════════════════════════════════════════════════════════════════════════════

# YouTube cookies file for yt-dlp (needed for age-restricted videos)
# Export with: yt-dlp --cookies-from-browser chrome --cookies /path/yt_cookies.txt https://youtube.com
# YOUTUBE_COOKIES_FILE=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Telegram Features
# ═══════════════════════════════════════════════════════════════════════════════

# Telegram API credentials (for reading channels via MTProto)
# Get from: https://my.telegram.org
# TG_API_ID=
# TG_API_HASH=

# Telegram session file path (stores authentication state)
# TG_SESSION_FILE=tg_session


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Twitter Features
# ═══════════════════════════════════════════════════════════════════════════════

# Twitter cookies file for yt-dlp (log into twitter.com in browser first)
# TWITTER_COOKIES_FILE=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Instagram Features
# ═══════════════════════════════════════════════════════════════════════════════

# Instagram login credentials
# INSTAGRAM_USER=
# INSTAGRAM_PASS=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Z-Library Features
# ═══════════════════════════════════════════════════════════════════════════════

# Z-Library account (register free at: https://z-library.sk/login)
# ZLIB_EMAIL=
# ZLIB_PASSWORD=


# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL — Spotify Features
# ═══════════════════════════════════════════════════════════════════════════════

# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=